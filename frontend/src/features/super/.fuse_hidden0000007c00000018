  standard: { bg: 'rgba(105,120,143,.12)', color: 'var(--color-muted)' },
};

type AuditRow = {
  id: string;
  time: string;
  actor: string;
  action: string;
  severity: Severity;
  object: string;
  ip: string;
};

const rows: AuditRow[] = [
  {
