<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Defs_SimCampaign"
                  targetNamespace="http://digishield.vn/bpmn">
  <bpmn:collaboration id="Collab_1">
    <bpmn:participant id="Pool_1" name="DigiShield - Simulation campaign" processRef="Proc_SimCampaign" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_SimCampaign" name="Simulation campaign" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Manager" name="Manager">
        <bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Config</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System" name="System (Worker)">
        <bpmn:flowNodeRef>T_Dispatch</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Bait</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Enroll</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Report</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Learner" name="Learner">
        <bpmn:flowNodeRef>T_Collect</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_1" name="Create campaign">
      <bpmn:outgoing>F1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="T_Config" name="Configure and schedule">
      <bpmn:incoming>F1</bpmn:incoming>
      <bpmn:outgoing>F2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Dispatch" name="Send simulation via queue">
      <bpmn:incoming>F2</bpmn:incoming>
      <bpmn:outgoing>F3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Collect" name="Collect open/click events">
      <bpmn:incoming>F3</bpmn:incoming>
      <bpmn:outgoing>F4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Bait" name="Took the bait?">
      <bpmn:incoming>F4</bpmn:incoming>
      <bpmn:outgoing>F_Yes</bpmn:outgoing>
      <bpmn:outgoing>F_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_Enroll" name="Auto-enroll course + coaching">
      <bpmn:incoming>F_Yes</bpmn:incoming>
      <bpmn:outgoing>F5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Report" name="Aggregate report">
      <bpmn:incoming>F5</bpmn:incoming>
      <bpmn:incoming>F_No</bpmn:incoming>
      <bpmn:outgoing>F6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_1" name="End">
      <bpmn:incoming>F6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F1" sourceRef="Start_1" targetRef="T_Config" />
    <bpmn:sequenceFlow id="F2" sourceRef="T_Config" targetRef="T_Dispatch" />
    <bpmn:sequenceFlow id="F3" sourceRef="T_Dispatch" targetRef="T_Collect" />
    <bpmn:sequenceFlow id="F4" sourceRef="T_Collect" targetRef="GW_Bait" />
    <bpmn:sequenceFlow id="F_Yes" name="Yes" sourceRef="GW_Bait" targetRef="T_Enroll" />
    <bpmn:sequenceFlow id="F_No" name="No" sourceRef="GW_Bait" targetRef="T_Report" />
    <bpmn:sequenceFlow id="F5" sourceRef="T_Enroll" targetRef="T_Report" />
    <bpmn:sequenceFlow id="F6" sourceRef="T_Report" targetRef="End_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diag_1">
    <bpmndi:BPMNPlane id="Plane_1" bpmnElement="Collab_1">
      <bpmndi:BPMNShape id="S_Pool_1" bpmnElement="Pool_1" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1130" height="360" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Lane_Manager" bpmnElement="Lane_Manager" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="1100" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Lane_System" bpmnElement="Lane_System" isHorizontal="true">
        <dc:Bounds x="190" y="200" width="1100" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Lane_Learner" bpmnElement="Lane_Learner" isHorizontal="true">
        <dc:Bounds x="190" y="320" width="1100" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Start_1" bpmnElement="Start_1">
        <dc:Bounds x="220" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="206" y="165" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_Config" bpmnElement="T_Config">
        <dc:Bounds x="300" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_Dispatch" bpmnElement="T_Dispatch">
        <dc:Bounds x="440" y="220" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_Collect" bpmnElement="T_Collect">
        <dc:Bounds x="600" y="340" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GW_Bait" bpmnElement="GW_Bait" isMarkerVisible="true">
        <dc:Bounds x="760" y="235" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="752" y="205" width="68" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_Enroll" bpmnElement="T_Enroll">
        <dc:Bounds x="850" y="220" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_Report" bpmnElement="T_Report">
        <dc:Bounds x="1020" y="220" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_End_1" bpmnElement="End_1">
        <dc:Bounds x="1190" y="242" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1184" y="285" width="50" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_F1" bpmnElement="F1">
        <di:waypoint x="256" y="140" /><di:waypoint x="300" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F2" bpmnElement="F2">
        <di:waypoint x="350" y="180" /><di:waypoint x="350" y="260" /><di:waypoint x="440" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F3" bpmnElement="F3">
        <di:waypoint x="495" y="300" /><di:waypoint x="495" y="380" /><di:waypoint x="600" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F4" bpmnElement="F4">
        <di:waypoint x="710" y="380" /><di:waypoint x="785" y="380" /><di:waypoint x="785" y="285" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F_Yes" bpmnElement="F_Yes">
        <di:waypoint x="810" y="260" /><di:waypoint x="850" y="260" />
        <bpmndi:BPMNLabel><dc:Bounds x="818" y="242" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F5" bpmnElement="F5">
        <di:waypoint x="970" y="260" /><di:waypoint x="1020" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F_No" bpmnElement="F_No">
        <di:waypoint x="785" y="235" /><di:waypoint x="785" y="200" /><di:waypoint x="1075" y="200" /><di:waypoint x="1075" y="220" />
        <bpmndi:BPMNLabel><dc:Bounds x="900" y="182" width="40" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F6" bpmnElement="F6">
        <di:waypoint x="1130" y="260" /><di:waypoint x="1190" y="260" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
