<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Defs_IncidentResponse"
                  targetNamespace="http://digishield.vn/bpmn">
  <bpmn:collaboration id="Collab_1">
    <bpmn:participant id="Pool_1" name="DigiShield - Handle reports and broadcast alerts" processRef="Proc_IncidentResponse" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_IncidentResponse" name="Handle reports and broadcast alerts" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Learner" name="User (Learner)">
        <bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System" name="System (AI/Reporting)">
        <bpmn:flowNodeRef>T_Save</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Classify</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Analyst" name="Analyst SOC">
        <bpmn:flowNodeRef>T_Triage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Threat</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Clean</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Notify" name="Notification">
        <bpmn:flowNodeRef>T_Broadcast</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Done</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_1" name="User reports">
      <bpmn:outgoing>F1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="T_Save" name="Save report">
      <bpmn:incoming>F1</bpmn:incoming>
      <bpmn:outgoing>F2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Classify" name="AI classify + cross-check blacklist">
      <bpmn:incoming>F2</bpmn:incoming>
      <bpmn:outgoing>F3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Triage" name="Analyst triage">
      <bpmn:incoming>F3</bpmn:incoming>
      <bpmn:outgoing>F4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Threat" name="Is it a threat?">
      <bpmn:incoming>F4</bpmn:incoming>
      <bpmn:outgoing>F_Yes</bpmn:outgoing>
      <bpmn:outgoing>F_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_Broadcast" name="Broadcast alert to organization">
      <bpmn:incoming>F_Yes</bpmn:incoming>
      <bpmn:outgoing>F5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Done" name="Completed">
      <bpmn:incoming>F5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Clean" name="Close - clean/spam">
      <bpmn:incoming>F_No</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F1" sourceRef="Start_1" targetRef="T_Save" />
    <bpmn:sequenceFlow id="F2" sourceRef="T_Save" targetRef="T_Classify" />
    <bpmn:sequenceFlow id="F3" sourceRef="T_Classify" targetRef="T_Triage" />
    <bpmn:sequenceFlow id="F4" sourceRef="T_Triage" targetRef="GW_Threat" />
    <bpmn:sequenceFlow id="F_Yes" name="Yes" sourceRef="GW_Threat" targetRef="T_Broadcast" />
    <bpmn:sequenceFlow id="F_No" name="No" sourceRef="GW_Threat" targetRef="End_Clean" />
    <bpmn:sequenceFlow id="F5" sourceRef="T_Broadcast" targetRef="End_Done" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diag_1">
    <bpmndi:BPMNPlane id="Plane_1" bpmnElement="Collab_1">
      <bpmndi:BPMNShape id="S_Pool_1" bpmnElement="Pool_1" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1000" height="480" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Lane_Learner" bpmnElement="Lane_Learner" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="970" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Lane_System" bpmnElement="Lane_System" isHorizontal="true">
        <dc:Bounds x="190" y="200" width="970" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Lane_Analyst" bpmnElement="Lane_Analyst" isHorizontal="true">
        <dc:Bounds x="190" y="320" width="970" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Lane_Notify" bpmnElement="Lane_Notify" isHorizontal="true">
        <dc:Bounds x="190" y="440" width="970" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Start_1" bpmnElement="Start_1">
        <dc:Bounds x="232" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="218" y="165" width="70" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_Save" bpmnElement="T_Save">
        <dc:Bounds x="320" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_Classify" bpmnElement="T_Classify">
        <dc:Bounds x="470" y="220" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_Triage" bpmnElement="T_Triage">
        <dc:Bounds x="640" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GW_Threat" bpmnElement="GW_Threat" isMarkerVisible="true">
        <dc:Bounds x="790" y="355" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="778" y="412" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_Broadcast" bpmnElement="T_Broadcast">
        <dc:Bounds x="880" y="460" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_End_Done" bpmnElement="End_Done">
        <dc:Bounds x="1060" y="482" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1055" y="525" width="50" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_End_Clean" bpmnElement="End_Clean">
        <dc:Bounds x="900" y="362" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="880" y="402" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_F1" bpmnElement="F1">
        <di:waypoint x="250" y="158" /><di:waypoint x="250" y="260" /><di:waypoint x="320" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F2" bpmnElement="F2">
        <di:waypoint x="420" y="260" /><di:waypoint x="470" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F3" bpmnElement="F3">
        <di:waypoint x="530" y="300" /><di:waypoint x="530" y="380" /><di:waypoint x="640" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F4" bpmnElement="F4">
        <di:waypoint x="740" y="380" /><di:waypoint x="790" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F_Yes" bpmnElement="F_Yes">
        <di:waypoint x="815" y="405" /><di:waypoint x="815" y="500" /><di:waypoint x="880" y="500" />
        <bpmndi:BPMNLabel><dc:Bounds x="820" y="450" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F_No" bpmnElement="F_No">
        <di:waypoint x="840" y="380" /><di:waypoint x="900" y="380" />
        <bpmndi:BPMNLabel><dc:Bounds x="852" y="362" width="40" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F5" bpmnElement="F5">
        <di:waypoint x="1000" y="500" /><di:waypoint x="1060" y="500" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
