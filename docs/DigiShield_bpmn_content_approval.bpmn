<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Defs_ContentApproval"
                  targetNamespace="http://digishield.vn/bpmn">
  <bpmn:collaboration id="Collab_1">
    <bpmn:participant id="Pool_1" name="DigiShield - AI content approval" processRef="Proc_ContentApproval" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_ContentApproval" name="AI content approval" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Editor" name="Content Editor">
        <bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Approve</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Reject</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_AI" name="AI Service">
        <bpmn:flowNodeRef>T_Gen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Moderate</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Publish" name="Publishing system">
        <bpmn:flowNodeRef>T_Publish</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Pub</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_1" name="Content creation request">
      <bpmn:outgoing>F1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="T_Gen" name="AI generates content">
      <bpmn:incoming>F1</bpmn:incoming>
      <bpmn:outgoing>F2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Moderate" name="Automated moderation">
      <bpmn:incoming>F2</bpmn:incoming>
      <bpmn:outgoing>F3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Review" name="Final reviewer">
      <bpmn:incoming>F3</bpmn:incoming>
      <bpmn:outgoing>F4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Approve" name="Approve?">
      <bpmn:incoming>F4</bpmn:incoming>
      <bpmn:outgoing>F_Yes</bpmn:outgoing>
      <bpmn:outgoing>F_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_Publish" name="Publish (approved)">
      <bpmn:incoming>F_Yes</bpmn:incoming>
      <bpmn:outgoing>F5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Pub" name="Ready to use">
      <bpmn:incoming>F5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Reject" name="Return for revision">
      <bpmn:incoming>F_No</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F1" sourceRef="Start_1" targetRef="T_Gen" />
    <bpmn:sequenceFlow id="F2" sourceRef="T_Gen" targetRef="T_Moderate" />
    <bpmn:sequenceFlow id="F3" sourceRef="T_Moderate" targetRef="T_Review" />
    <bpmn:sequenceFlow id="F4" sourceRef="T_Review" targetRef="GW_Approve" />
    <bpmn:sequenceFlow id="F_Yes" name="Pass" sourceRef="GW_Approve" targetRef="T_Publish" />
    <bpmn:sequenceFlow id="F_No" name="Fail" sourceRef="GW_Approve" targetRef="End_Reject" />
    <bpmn:sequenceFlow id="F5" sourceRef="T_Publish" targetRef="End_Pub" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diag_1">
    <bpmndi:BPMNPlane id="Plane_1" bpmnElement="Collab_1">
      <bpmndi:BPMNShape id="S_Pool_1" bpmnElement="Pool_1" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1010" height="360" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Lane_Editor" bpmnElement="Lane_Editor" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="980" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Lane_AI" bpmnElement="Lane_AI" isHorizontal="true">
        <dc:Bounds x="190" y="200" width="980" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Lane_Publish" bpmnElement="Lane_Publish" isHorizontal="true">
        <dc:Bounds x="190" y="320" width="980" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Start_1" bpmnElement="Start_1">
        <dc:Bounds x="232" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="215" y="165" width="76" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_Gen" bpmnElement="T_Gen">
        <dc:Bounds x="320" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_Moderate" bpmnElement="T_Moderate">
        <dc:Bounds x="470" y="220" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_Review" bpmnElement="T_Review">
        <dc:Bounds x="660" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GW_Approve" bpmnElement="GW_Approve" isMarkerVisible="true">
        <dc:Bounds x="810" y="115" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="803" y="85" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_Publish" bpmnElement="T_Publish">
        <dc:Bounds x="900" y="340" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_End_Pub" bpmnElement="End_Pub">
        <dc:Bounds x="1080" y="362" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1070" y="402" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_End_Reject" bpmnElement="End_Reject">
        <dc:Bounds x="920" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="900" y="162" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_F1" bpmnElement="F1">
        <di:waypoint x="250" y="158" /><di:waypoint x="250" y="260" /><di:waypoint x="320" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F2" bpmnElement="F2">
        <di:waypoint x="420" y="260" /><di:waypoint x="470" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F3" bpmnElement="F3">
        <di:waypoint x="530" y="220" /><di:waypoint x="530" y="140" /><di:waypoint x="660" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F4" bpmnElement="F4">
        <di:waypoint x="760" y="140" /><di:waypoint x="810" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F_Yes" bpmnElement="F_Yes">
        <di:waypoint x="835" y="165" /><di:waypoint x="835" y="380" /><di:waypoint x="900" y="380" />
        <bpmndi:BPMNLabel><dc:Bounds x="840" y="330" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F_No" bpmnElement="F_No">
        <di:waypoint x="860" y="140" /><di:waypoint x="920" y="140" />
        <bpmndi:BPMNLabel><dc:Bounds x="866" y="122" width="56" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F5" bpmnElement="F5">
        <di:waypoint x="1020" y="380" /><di:waypoint x="1080" y="380" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
